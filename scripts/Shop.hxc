        }

        persistentUpdate = true;

        camera.minScrollX = wall.x;
        camera.maxScrollX = wall.x + wall.width;
        camera.minScrollY = wall.y;
        camera.maxScrollY = counter.y + counter.height - 25;

        refresh();

        super.create();
    }

    override public function update(elapsed:Float):Void
    {
        super.update(elapsed);
        
        var lerpval:Float = FlxMath.bound(elapsed * 9.6, 0, 1);
        funkBucksText.y = FlxMath.lerp(funkBucksText.y, 25, lerpval);

        if (controls.BACK_P)
        {
            goBack();
        }

        if ((controls.ACCEPT_P || TouchUtil.pressAction()) && canContinue)
        {
            switch (STATE)
            {
                case "OPHELIAPIN":
                {
                    unlockOpheliaPin();
                }
                case "OPHELIAANGERINITIAL":
                {
                    opheliaAngerDialogue();
                }
                case "OPHELIAANGERREPEAT":
                {
                    opheliaAngerRepeatDialogue();
                }
                default: {}
            }
        }

        if (disallowInputs)
        {
            coolBackButton.enabled = false;
            return;
        }
        coolBackButton.visible = FlxG.onMobile ? true : PointlessPins.isMouseActive;
        coolBackButton.enabled = true;

        var isMouseTooFast:Bool = FlxG.onMobile ? false : Math.abs(FlxG.mouse.deltaViewX) > 2 || Math.abs(FlxG.mouse.deltaViewY) > 2;

        handleCameraMovement();
        checkIfAnnoyedOphelia(isMouseTooFast);

        // Pins

        if (FlxG.keys.justPressed.ONE || (TouchUtil.pressAction(iconPins) && !isMouseTooFast && !TouchUtil.overlaps(coolBackButton, cameraHUD)))
        {
            disallowInputs = true;
            cameraFollowPoint.setPosition(iconPins.x + iconPins.width / 2, iconPins.y + 50);

            var substate = new PinBoard();
            substate.closeCallback = function()
            {
                FlxTween.tween(coolBackButton, { alpha: 0.5 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(camera, { zoom: 1 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(funkBucksText, { alpha: 1 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(screenBlack, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
            };
            substate.cameras = [cameraSubState];

            FlxTween.tween(coolBackButton, { alpha: 0 }, 1, { ease: FlxEase.cubeIn });
            FlxTween.tween(camera, { zoom: 1.5 }, 1, { ease: FlxEase.cubeIn });
            FlxTween.tween(funkBucksText, { alpha: 0 }, 1, { ease: FlxEase.cubeIn });
            FlxTween.tween(screenBlack, { alpha: 0.8 }, 1, { ease: FlxEase.cubeIn, onComplete: function()
            {
                openSubState(substate);
            }});
        }

        // Boxes

        if (FlxG.keys.justPressed.TWO || (TouchUtil.pressAction(iconBoxes) && !isMouseTooFast && !TouchUtil.overlaps(coolBackButton, cameraHUD)))
        {
            disallowInputs = true;
            cameraFollowPoint.setPosition(iconBoxes.x + iconBoxes.width / 2, iconBoxes.y - 4);
            showMenuItems(false);

            var substate = new BoxSubMenu();
            substate.closeCallback = function()
            {
                FlxTween.tween(coolBackButton, { alpha: 0.5 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(camera, { zoom: 1 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(screenBlack, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
                showMenuItems();
            }
            substate.cameras = [cameraSubState];

            FlxTween.tween(coolBackButton, { alpha: 0 }, 1, { ease: FlxEase.cubeIn });
            FlxTween.tween(screenBlack, { alpha: 0.5 }, 1, { ease: FlxEase.cubeIn });
            FlxTween.tween(camera, { zoom: 0.9 }, 1, { ease: FlxEase.cubeOut, onComplete: function()
            {
                openSubState(substate);
            }});
        }

        // Help

        // if (FlxG.keys.justPressed.THREE || (TouchUtil.pressAction(lableHelp) && !isMouseTooFast && !TouchUtil.overlaps(coolBackButton, cameraHUD)))
        // {
            // disallowInputs = true;
            // STATE = "HELP";
            // cameraFollowPoint.setPosition(ophelia.x - 50, 360);
            // showMenuItems(false);
            // ophelia.playAnimation("IdleHandDown", true, true);
            // FlxTween.tween(camera, { zoom: 1.5 }, 1, { ease: FlxEase.cubeOut });
            // FlxTween.tween(counter, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
            // FlxTween.tween(cameraHUD, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
        // }

        // Rewards

        // if (FlxG.keys.justPressed.M || (TouchUtil.pressAction(lableRewards) && !isMouseTooFast && !TouchUtil.overlaps(coolBackButton, cameraHUD)))
        // {
            // disallowInputs = true;
            // cameraFollowPoint.setPosition(lableRewards.x - 150, 300);
            // showMenuItems(false);
            // ophelia.playAnimation("IdleHandDown", true, true);
            // FlxTween.tween(camera, { zoom: 1.5 }, 1, { ease: FlxEase.cubeOut });
            // FlxTween.tween(counter, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
        // }

        justGainedFocus = false;
    }

    function goBack():Void
    {
        if (STATE == "HELP")
        {
            cameraFollowPoint.setPosition(ophelia.x, 300);
            ophelia.playAnimation("Idle", true, true);
            showMenuItems();
            FlxTween.tween(camera, { zoom: 1 }, 1, { ease: FlxEase.cubeOut });
            FlxTween.tween(counter, { alpha: 1 }, 1, { ease: FlxEase.cubeOut });
            FlxTween.tween(cameraHUD, { alpha: 1 }, 1, { ease: FlxEase.cubeIn });
            disallowInputs = false;
            STATE = "MAIN";
            return;
        }
        if (disallowInputs) return;
        FlxG.switchState(() -> new MainMenuState());
    }

    function handleCameraMovement():Void
    {
        var moveSpeed:Float = 50;

        // Stop flinging the camera if we just got focus.
        if (justGainedFocus || disallowInputs) return;

        // No using FlxG.updateFramerate, as it seems to shorten down the dragging distance drastically when at higher framerates.

        // Touch Dragging
        if (FlxG.onMobile)
        {
            for (touch in FlxG.touches.list)
            {
                if (touch.pressed)
                {
                    final deltaX = touch.deltaViewX;
                    if (Math.abs(deltaX) > 2)
                    {
                        var dpiScale = FlxG.stage.window.display.dpi / 160;
                        dpiScale = FlxMath.bound(dpiScale, 0.5, 1);
                        var moveLength = (deltaX * moveSpeed * 1.5) / 60 / dpiScale;
                        cameraFollowPoint.x -= moveLength;
                    }

                    final deltaY = touch.deltaViewY;
                    if (Math.abs(deltaY) > 2)
                    {
                        var dpiScale = FlxG.stage.window.display.dpi / 160;
                        dpiScale = FlxMath.bound(dpiScale, 0.5, 1);
                        var moveLength = (deltaY * moveSpeed * 1.5) / 60 / dpiScale;
                        cameraFollowPoint.y -= moveLength;
                    }
                }
            }
        }

        // Mouse Dragging
        if (FlxG.mouse.pressed && !FlxG.onMobile)
        {
            final deltaX = FlxG.mouse.deltaViewX;
            if (Math.abs(deltaX) > 2)
            {
                var dpiScale = FlxG.stage.window.display.dpi / 160;
                dpiScale = FlxMath.bound(dpiScale, 0.5, 1);
                var moveLength = (deltaX * moveSpeed) / 60 / dpiScale;
                cameraFollowPoint.x -= moveLength;
            }

            final deltaY = FlxG.mouse.deltaViewY;
            if (Math.abs(deltaY) > 2)
            {
                var dpiScale = FlxG.stage.window.display.dpi / 160;
                dpiScale = FlxMath.bound(dpiScale, 0.5, 1);
                var moveLength = (deltaY * moveSpeed) / 60 / dpiScale;
                cameraFollowPoint.y -= moveLength;
            }
        }

        // Mouse Scrolling (Only Horizontal)
        if (FlxG.mouse.wheel != 0)
        {
            cameraFollowPoint.x -= FlxG.mouse.wheel * moveSpeed;
        }

        // Let's not go Mach 3 while at 500 FPS, ok?
        moveSpeed *= elapsed;
        // Keyboard Controls
        if (controls.UI_LEFT) cameraFollowPoint.x -= moveSpeed * 30;
        if (controls.UI_RIGHT) cameraFollowPoint.x += moveSpeed * 30;
        if (controls.UI_UP) cameraFollowPoint.y -= moveSpeed * 30;
        if (controls.UI_DOWN) cameraFollowPoint.y += moveSpeed * 30;

        cameraFollowPoint.x = FlxMath.bound(cameraFollowPoint.x, camera.minScrollX, camera.maxScrollX);
        cameraFollowPoint.y = FlxMath.bound(cameraFollowPoint.y, camera.minScrollY, camera.maxScrollY);
    }

    function showMenuItems(show:Bool = true):Void
    {
        if (show)
        {
            for (item in counterItems)
            {
                FlxTween.tween(item, { alpha: 1 }, 1, { ease: FlxEase.cubeIn });
            }
        }
        else
        {
            for (item in counterItems)
            {
                FlxTween.tween(item, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
            }
        }
    }

    /**
     * 50 taps: Ophelia gives a Pin of herself.
     * 75 taps: Warning.
     * 100 taps: +1 to her anger count.
     */
    function checkIfAnnoyedOphelia(isMouseTooFast:Bool):Void
    {
        // Ophelia's sprite extends behind the counter, we don't wanna count pressing in that area as well.
        if (TouchUtil.pressAction(opheliaHitbox, camera) && !TouchUtil.overlaps(coolBackButton, cameraHUD) && !isMouseTooFast)
        {
            ophelia.annoyance++;
            trace("Boop! " + ophelia.annoyance);

            if (ophelia.annoyance == 50 && !PointlessPins.hasObtainedPin("ophelia"))
            {
                dialogueText.text = "Hey,<d=0.25/> if I give you this,<d=0.25/> you'll leave me be,<d=0.5/> 'kay?";
                new FlxTimer().start(0.5, function(_:FlxTimer) {
                    dialogueBar.alpha = 0.75;
                    dialogueText.startTyping();
                });

                STATE = "OPHELIAPIN";
                disallowInputs = true;
                showMenuItems(false);
                cameraFollowPoint.setPosition(opheliaHitbox.x + opheliaHitbox.width / 2, opheliaHitbox.y + 115);
                FlxTween.tween(camera, { zoom: 1.5 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(funkBucksText, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
                new FlxTimer().start(4, function(_:FlxTimer) {
                    canContinue = true;
                });
                coolBackButton.visible = false;
                trace("Enough booping!");
                return;
            }

            if (ophelia.annoyance == 75 && PointlessPins.getOpheliaAnger() == 0)
            {
                dialogueBar.alpha = 0.75;
                dialogueText.text = "I told you to leave me be,<d=0.5/> didn't I?";
                dialogueText.visible = true;
                dialogueText.reset();
                dialogueText.startTyping();
                dialogueDisappearTimer = new FlxTimer().start(4, function(_:FlxTimer) {
                    dialogueText.visible = false;
                    dialogueBar.alpha = 0;
                });
            }

            if (ophelia.annoyance % 100 == 0)
            {
                if (PointlessPins.getOpheliaAnger() == 0)
                {
                    dialogueCount = 0;
                    disallowInputs = true;
                    if (PointlessPins.getOpheliaAngerTotal() > 0)
                    {
                        STATE = "OPHELIAANGERREPEAT";
                        opheliaAngerRepeatDialogue();
                    }
                    else
                    {
                        STATE = "OPHELIAANGERINITIAL";
                        opheliaAngerDialogue();
                    }
                    PointlessPins.save.opheliaAngerTime = Date.now().getTime();
                }
                PointlessPins.addOpheliaAnger(1);
                trace("FUCK YOU!!!!");
                return;
            }

            ophelia.playAnimation("GetTappedOn1", false, true);
        }
    }

    function unlockOpheliaPin():Void
    {
        canContinue = false;
        ophelia.playAnimation("PickingPin", false, true);
        FlxTween.tween(dialogueBar, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
        FlxTween.tween(dialogueText, { alpha: 0 }, 1, { ease: FlxEase.cubeOut, onComplete: () -> {
            dialogueText.visible = false;
            dialogueText.alpha = 1;
        }});
        FlxTween.tween(cameraFollowPoint, { x: cameraFollowPoint.x - 50, y: cameraFollowPoint.y + 25 }, 2, { ease: FlxEase.cubeOut });
        var substate = new PinUnlockState(PointlessPins.getPinByID("ophelia"));
        substate.cameras = [cameraSubState];
        substate.closeCallback = () -> {
            STATE = "MAIN";
            disallowInputs = false;
            showMenuItems(true);
            FlxTween.tween(camera, { zoom: 1 }, 1, { ease: FlxEase.cubeOut });
            FlxTween.tween(funkBucksText, { alpha: 1 }, 1, { ease: FlxEase.cubeOut });
        }
        new FlxTimer().start(70 / 24, (_:FlxTimer) -> {
            FlxTween.tween(cameraFollowPoint, { x: cameraFollowPoint.x - 100, y: cameraFollowPoint.y + 50 }, 14 / 24, { ease: FlxEase.cubeOut });
        });
        new FlxTimer().start(84 / 24, (_:FlxTimer) -> {
            openSubState(substate);
            FlxTween.tween(camera, { zoom: 1.25 }, 1, { ease: FlxEase.cubeOut });
            ophelia.playAnimation("Idle", true, true);
        });
    }

    function opheliaAngerDialogue():Void
    {
        switch (dialogueCount)
        {
            case 0:
            {
                canContinue = false;
                showMenuItems(false);
                dialogueDisappearTimer?.cancel();
                dialogueBar.alpha = 0.75;
                dialogueText.finish();
                dialogueText.text = "You're not very smart,<d=0.5/> <i>are you?</i>";
                dialogueText.visible = true;
                dialogueText.reset();
                dialogueText.startTyping();
                cameraFollowPoint.setPosition(opheliaHitbox.x + opheliaHitbox.width / 2, opheliaHitbox.y + 100);
                FlxTween.tween(camera, { zoom: 1.5 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(funkBucksText, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
                coolBackButton.visible = false;
                new FlxTimer().start(3, function(_:FlxTimer) {
                    canContinue = true;
                });
                dialogueCount = 1;
            }
            case 1:
            {
                canContinue = false;
                dialogueText.text = "I warned you,<d=0.25/> but you didn't take the hint,<d=0.25/> eh?";
                dialogueText.startTyping();
                new FlxTimer().start(4, function(_:FlxTimer) {
                    canContinue = true;
                });
                dialogueCount = 2;
            }
            case 2:
            {
                canContinue = false;
                dialogueText.text = "Have fun with the <c=FF7F7F>marked up prices</c>,<d=0.25/> idiot.";
                dialogueText.startTyping();
                new FlxTimer().start(4, function(_:FlxTimer) {
                    canContinue = true;
                });
                dialogueCount = 3;
            }
            case 3:
            {
                STATE = "MAIN";
                disallowInputs = false;
                showMenuItems(true);
                dialogueText.visible = false;
                dialogueBar.alpha = 0;
                FlxTween.tween(camera, { zoom: 1 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(funkBucksText, { alpha: 1 }, 1, { ease: FlxEase.cubeOut });
                dialogueCount = -1;
            }
        }
    }

    function opheliaAngerRepeatDialogue():Void
    {
        switch (dialogueCount)
        {
            case 0:
            {
                canContinue = false;
                showMenuItems(false);
                dialogueDisappearTimer?.cancel();
                dialogueBar.alpha = 0.75;
                dialogueText.finish();
                dialogueText.text = "Didn't you learn from last time!?";
                dialogueText.visible = true;
                dialogueText.reset();
                dialogueText.startTyping();
                cameraFollowPoint.setPosition(opheliaHitbox.x + opheliaHitbox.width / 2, opheliaHitbox.y + 100);
                FlxTween.tween(camera, { zoom: 1.5 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(funkBucksText, { alpha: 0 }, 1, { ease: FlxEase.cubeOut });
                coolBackButton.visible = false;
                new FlxTimer().start(2.5, function(_:FlxTimer) {
                    canContinue = true;
                });
                dialogueCount = 1;
            }
            case 1:
            {
                canContinue = false;
                dialogueText.letterStep = 10;
                dialogueText.y += 10;
                dialogueText.text = "<c=FF0000><S><s=1.5>STOP!</s></S></c>";
                dialogueText.startTyping();
                new FlxTimer().start(1, function(_:FlxTimer) {
                    canContinue = true;
                });
                dialogueCount = 2;
            }
            case 2:
            {
                canContinue = false;
                dialogueText.letterStep = 1;
                dialogueText.speed = 0.035;
                dialogueText.y -= 10;
                dialogueText.text = "Or do you like <c=FF7F7F>paying more for the boxes</c>,<d=1.0/> <S>huh?!</S>";
                dialogueText.startTyping();
                new FlxTimer().start(4, function(_:FlxTimer) {
                    canContinue = true;
                });
                dialogueCount = 3;
            }
            case 3:
            {
                STATE = "MAIN";
                disallowInputs = false;
                showMenuItems(true);
                dialogueText.speed = 0.05;
                dialogueText.visible = false;
                dialogueBar.alpha = 0;
                FlxTween.tween(camera, { zoom: 1 }, 1, { ease: FlxEase.cubeOut });
                FlxTween.tween(funkBucksText, { alpha: 1 }, 1, { ease: FlxEase.cubeOut });
                dialogueCount = -1;
            }
        }
    }

    var previousFunkBucks:Int;
    public function deductFunkBucks(amount:Int):Void
    {
        var currentFunkBucks:Int = previousFunkBucks = PointlessPins.getFunkCoins();
        var remainingFunkBucks:Int = currentFunkBucks - amount;

        var easeToUse:FlxEase = amount >= 500 ? FlxEase.expoOut : FlxEase.quartOut;
        FlxTween.num(currentFunkBucks, remainingFunkBucks, 2.5, { ease: easeToUse, onComplete: function(_) {
            funkBucksText.text = '<b>${Math.floor(remainingFunkBucks)}</b> &#xE000;';
        }}, updateFunkBucks);

        PointlessPins.addFunkCoins(-amount, false);
    }

    function updateFunkBucks(value:Float):Void
    {
        if (previousFunkBucks != Math.floor(value))
        {
            funkBucksText.text = '<b>${Math.floor(value)}</b> &#xE000;';
            funkBucksText.y += 7;
            FunkinSound.playOnce(Paths.sound("fav"), 0.5);
        }
        previousFunkBucks = Math.floor(value);
    }

    function insufficientFunkBucks():Void
    {
        funkBucksText.y += 20;
        FlxTween.color(funkBucksText, 0.5, 0xFFFF0000, 0xFFFFFFFF);
        FunkinSound.playOnce(Paths.sound("CS_locked"));
    }

    function formatDailySongs():String
    {
        var dailies:Array<String> = PointlessPins.getDailies();
        // return "<b><c=00FF00>Dailies</c>\nPhilly Nic. &#xE003;\nSatin Pant. &#xE001;\nWinter Hor.</b>";
        if (dailies.length > 0)
        {
            var dailiesList:String = "";
            for (i in 0...3)
            {
                if (i >= dailies.length)
                {
                    dailiesList += "---";
                    if (i < 2) dailiesList += "\n";
                    continue;
                }
                var dailySongName:String = dailies[i].substring(0, dailies[i].lastIndexOf("-"));
                var dailySongVariation:String = dailies[i].substring(dailies[i].lastIndexOf("-") + 1, dailies[i].length);
                var dailySong:Array<SongMetadata> = SongRegistry.instance.fetchEntry(dailySongName);
                var songNameToAdd:String = dailySong.songName.length > 10 ? dailySong.songName.substr(0, 10).trim() + "." : dailySong.songName;
                var variationToAdd:String = "";
                for (variation in dailySong.getRawMetadata())
                {
                    if (variation.variation != dailySongVariation) continue;
                    switch (variation.variation)
                    {
                        case "default": // Nothing gets added to default variation names.
                        case "erect": variationToAdd = " &#xE001;";
                        case "bf": variationToAdd = " &#xE002;";
                        case "pico": variationToAdd = " &#xE003;";
                        default: trace('Not a base variation, how\'d this get in here?? - ${variation.variation}');
                    }
                } 
                dailiesList += songNameToAdd + variationToAdd;
                if (i < 2) dailiesList += "\n";
            }
            return '<b><c=00FF00>Dailies</c>\n${dailiesList}</b>';
        }
        else
        {
            return "<b><c=00FF00>Dailies</c>\nNone!\nCome back\ntomorrow!</b>";
        }
    }

    override function onFocus():Void
    {
        justGainedFocus = true;
    }

    override function openSubState(state):Void
    {
        cameraSubState.scroll.set(0, 0);
        cameraSubState.follow(null);
         // Necessary, otherwise you can move the camera during transitions, which sets this to false?????
        disallowInputs = true;

        super.openSubState(state);
    }

    override function closeSubState():Void
    {
        new FlxTimer().start(0.1, function(_:FlxTimer) {
            disallowInputs = false;
        });
        STATE = "MAIN";
        super.closeSubState();
    }

    override function destroy():Void
    {
        if (!FlxG.onMobile) FlxMouseEvent.remove(coolBackButton);
        super.destroy();
    }
}