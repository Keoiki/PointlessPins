        funkBucksText.setScale(0.75);
        funkBucksText.alignment = "right";
        funkBucksText.scrollFactor.set(0, 0);
        add(funkBucksText);

        dialogueBar = new FunkinSprite(0, 32).makeSolidColor(FlxG.width, 96, 0xFF000000);
        dialogueBar.alpha = 0.0;
