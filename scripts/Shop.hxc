        }
        add(coolBackButton);

        screenBlack.cameras = [cameraHUD];
        funkBucksText.cameras = [cameraHUD];
        dialogueBar.cameras = [cameraHUD];
        dialogueText.cameras = [cameraHUD];
        coolBackButton.cameras = [cameraHUD];

        if (ModStore.get("pinsIsOutdated") && ModStore.get("pinsHasShownOutdate") == null)
        {
            var alert:BAlphabet = new BAlphabet(FlxG.width / 2, FlxG.height - 45, '<c=00FF00><b>Version ${ModStore.get("pinsOnlineVersion")} is available!</b></c>');
            alert.alignment = "center";
            alert.setScale(0.5);
            alert.zIndex = 100000;
            add(alert);
            alert.cameras = [cameraHUD];
